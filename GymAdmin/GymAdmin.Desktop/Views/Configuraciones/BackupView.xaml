<UserControl x:Class="GymAdmin.Desktop.Views.Configuraciones.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Error global -->
                <Border Background="#FFfdecea"
                        BorderBrush="#FFf5c2c7"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Margin="16,16,16,0"
                        Visibility="{Binding ErrorMessage, 
                    Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                    Text="{Binding ErrorMessage}"
                                    Foreground="#FF58151c"
                                    TextWrapping="Wrap"
                                    VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Content="✕"
                                Margin="8,0,0,0"
                                Padding="6,0"
                                Width="32"
                                Height="28"
                                VerticalAlignment="Top"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding ClearErrorCommand}" />
                    </Grid>
                </Border>

                <!-- Info global -->
                <Border Background="#FFE8F4FD"
                        BorderBrush="#FFB6E0FE"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Margin="16,12,16,0"
                        Visibility="{Binding InfoMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                    Text="{Binding InfoMessage}"
                                    Foreground="#FF0C5460"
                                    TextWrapping="Wrap"
                                    VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Content="✕"
                                Margin="8,0,0,0"
                                Padding="6,0"
                                Width="32"
                                Height="28"
                                VerticalAlignment="Top"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding ClearInfoCommand}" />
                    </Grid>
                </Border>

                <GroupBox Header="Crear backup" Margin="16,16,16,0">
                    <StackPanel Margin="16">

                        <TextBlock Text="Genera una copia de seguridad manual de la base de datos actual."
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Ver backups"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AbrirCarpetaBackupsCommand}"
                                    Width="130"
                                    Margin="0,0,8,0" />

                            <Button Content="Crear backup"
                                    Command="{Binding CrearBackupManualCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="130" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Restaurar backup" Margin="16">
                    <StackPanel Margin="16">

                        <TextBlock Text="Archivo ZIP seleccionado:" />

                        <TextBox Text="{Binding SelectedBackupPath, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Margin="0,8,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Seleccionar"
                                    Command="{Binding SeleccionarBackupCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="100"
                                    Margin="0,0,8,0" />

                            <Button Content="Restaurar"
                                    Command="{Binding RestaurarBackupCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="100" />
                        </StackPanel>

                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="DialogOverlay"
              Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#80000000"
              Panel.ZIndex="1000"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              MouseDown="DialogOverlay_MouseDown">
            <ContentControl Content="{Binding DialogContent}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>